{
  "name": "campgo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outdir=dist-server --packages=external",
    "build:all": "npm run build && npm run build:server",
    "start": "NODE_ENV=production node dist-server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && eslint './**/*.{ts,tsx}' --ignore-pattern dist/ --ignore-pattern node_modules/",
    "lint:eslint": "eslint './**/*.{ts,tsx}' --ignore-pattern dist/ --ignore-pattern node_modules/",
    "format": "prettier --write './**/*.{ts,tsx,json,css}' --ignore-path ../.prettierignore",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.0.0",
    "@sentry/node": "^10.60.0",
    "@sentry/react": "^10.60.0",
    "@tanstack/react-router": "^1.170.16",
    "appwrite": "^26.0.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.11.0",
    "nanoid": "^5.1.0",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.55.0",
    "recharts": "^2.15.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "sonner": "^2.0.0",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "postcss": "^8.5.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.6"
  }
}
